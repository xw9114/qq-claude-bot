# NoneBot
DRIVER=~fastapi+~httpx+~websockets
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
COMMAND_START=["/"]
SUPERUSERS=[]
TITLE_ADMINS=[]
BOT_GLOBAL_SEND_INTERVAL=1
BOT_GROUP_SEND_INTERVAL=3
BOT_USER_SEND_COOLDOWN=5

# OpenAI-compatible API
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
MEMES_COMMAND_PREFIXES=["/"]

# Web search (optional)
# 联网搜索结果数量
WEB_SEARCH_MAX_RESULTS=5
# 同一会话触发 /联网 的冷却秒数，设为 0 可关闭
WEB_SEARCH_COMMAND_COOLDOWN=15
# 联网回答最大字符数
WEB_SEARCH_REPLY_MAX_CHARS=900

# Voice (optional)
# QQ AI 声聊默认角色 ID，留空则自动使用群角色列表的第一个
VOICE_AI_CHARACTER=
# edge-tts 在线合成默认音色
VOICE_EDGE_VOICE=zh-CN-XiaoxiaoNeural
# 单条语音的最大文本长度
VOICE_MAX_TEXT_LEN=200
# 同一会话触发 /语音 的冷却秒数，设为 0 可关闭
VOICE_COMMAND_COOLDOWN=10

# Music (optional)
# 兼容 NeteaseCloudMusicApi（Binaryify）协议的搜索服务地址，留空则 /点歌 只支持直接发 ID/链接
MUSIC_API_BASE_URL=
# 单曲下载大小上限（MB）
MUSIC_MAX_SIZE_MB=15
# 同一会话触发 /点歌 的冷却秒数，设为 0 可关闭
MUSIC_COMMAND_COOLDOWN=30

# Third-party plugins
DATABASE_URL=sqlite+aiosqlite:///data/database.db
BOARDGAME_TIMEOUT=600
